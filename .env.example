# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token
ADMIN_TELEGRAM_ID=your-telegram-user-id   # your numeric Telegram user ID

# ── WhatsApp / Twilio ─────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886  # Twilio sandbox or your WA business number

# ── eBay API ──────────────────────────────────────────────
EBAY_APP_ID=your-app-id
EBAY_CLIENT_SECRET=your-client-secret

# ── pokemontcg.io ─────────────────────────────────────────
POKEMONTCG_API_KEY=your-api-key           # optional, raises rate limit

# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID=price_xxx                 # $5/mo subscription price ID

# ── App ───────────────────────────────────────────────────
APP_ENV=development                       # development | production
BASE_URL=https://yourdomain.com           # used for Stripe redirect URLs
SECRET_KEY=change-me-to-random-string     # for signing session tokens

# ── Anthropic (Claude vision OCR) ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx
